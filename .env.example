# Google Places API key
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "Places API" in your project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic API key
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: your name for the email signature
YOUR_NAME=Your Name

# Gmail address you'll send outreach emails FROM
EMAIL_FROM=you@gmail.com

# Gmail App Password (NOT your regular password)
# Enable 2-Step Verification, then go to:
# myaccount.google.com → Security → 2-Step Verification → App passwords
# Generate one for "Mail" / "Windows Computer" and paste it here (spaces OK)
EMAIL_PASS=xxxx xxxx xxxx xxxx
